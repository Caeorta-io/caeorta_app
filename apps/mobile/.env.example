# Caeorta mobile (Expo) environment variables.
# Copy this file to `.env.local` (gitignored) and fill values from the 1Password "Caeorta" vault.
# Mobile uses the EXPO_PUBLIC_* prefix, so these are inlined into the JS bundle at build time —
# never put a server-only secret here. Preview/prod values are set via the EAS dashboard.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=
EXPO_PUBLIC_APP_ENV=
