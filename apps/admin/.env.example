# Caeorta admin (Next.js) environment variables.
# Copy this file to `.env.local` (gitignored) and fill values from the 1Password "Caeorta" vault.
# NEXT_PUBLIC_* are exposed to the browser; everything else is server-only — never prefix a
# secret with NEXT_PUBLIC_. Preview/prod values are set via the Vercel dashboard.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_ENV=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
RESEND_API_KEY=
